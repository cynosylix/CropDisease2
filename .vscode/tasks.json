{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start ML Server",
      "type": "shell",
      "command": "uvicorn server:app --host 0.0.0.0 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/ml_server",
        "env": {}
      },
      "problemMatcher": {
        "owner": "ml-server",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Waiting for application startup",
          "endsPattern": "Application startup complete|Model loaded"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "echo": true
      },
      "isBackground": true,
      "runOptions": {
        "instanceLimit": 1
      }
    }
  ]
}
